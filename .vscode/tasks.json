{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "app-init",
            "type": "shell",
            "command": "make",
            "args": ["app-init"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Initialize the application (migrate, seed, and run)"
        },
        {
            "label": "app-migrate",
            "type": "shell",
            "command": "go",
            "args": ["build", "-o", "${workspaceFolder}/powerxctl", "${workspaceFolder}/cmd/ctl/powerxctl.go"],
            "group": "build",
            "detail": "Build and run database migrations"
        },
        {
            "label": "run-migrate",
            "type": "shell",
            "command": "${workspaceFolder}/powerxctl",
            "args": ["database", "migrate", "-f", "${workspaceFolder}/etc/powerx.yaml"],
            "group": "build",
            "detail": "Run database migrations"
        },
        {
            "label": "app-seed",
            "type": "shell",
            "command": "go",
            "args": ["build", "-o", "${workspaceFolder}/powerxctl", "${workspaceFolder}/cmd/ctl/powerxctl.go"],
            "group": "build",
            "detail": "Build and run database seeding"
        },
        {
            "label": "run-seed",
            "type": "shell",
            "command": "${workspaceFolder}/powerxctl",
            "args": ["database", "seed", "-f", "${workspaceFolder}/etc/powerx.yaml"],
            "group": "build",
            "detail": "Run database seeding"
        },
        {
            "label": "app-run",
            "type": "shell",
            "command": "go",
            "args": ["build", "-o", "${workspaceFolder}/powerx", "${workspaceFolder}/cmd/server/powerx.go"],
            "group": "build",
            "detail": "Build and run the application"
        },
        {
            "label": "run-app",
            "type": "shell",
            "command": "${workspaceFolder}/powerx",
            "args": ["-f", "${workspaceFolder}/etc/powerx.yaml"],
            "group": "build",
            "detail": "Run the application"
        },
        {
            "label": "app-build-linux",
            "type": "shell",
            "command": "go",
            "args": [
                "build",
                "-o", "${workspaceFolder}/.build/linux/powerx",
                "${workspaceFolder}/cmd/server/powerx.go"
            ],
            "options": {
                "env": {
                    "CGO_ENABLED": "0",
                    "GOOS": "linux",
                    "GOARCH": "amd64"
                }
            },
            "group": "build",
            "detail": "Build for Linux"
        },
        {
            "label": "app-build-linux-ctl",
            "type": "shell",
            "command": "go",
            "args": [
                "build",
                "-o", "${workspaceFolder}/.build/linux/powerxctl",
                "${workspaceFolder}/cmd/ctl/powerxctl.go"
            ],
            "options": {
                "env": {
                    "CGO_ENABLED": "0",
                    "GOOS": "linux",
                    "GOARCH": "amd64"
                }
            },
            "group": "build",
            "detail": "Build CLI for Linux"
        },
        {
            "label": "build-goctl-powerx-apis",
            "type": "shell",
            "command": "goctl",
            "args": ["api", "go", "-api", "${workspaceFolder}/api/powerx.api", "-dir", "${workspaceFolder}"],
            "group": "build",
            "detail": "Generate Go code from API definition"
        },
        {
            "label": "build-image",
            "type": "shell",
            "command": "docker",
            "args": ["build", "-t", "powerx:latest", "${workspaceFolder}/deploy/docker"],
            "group": "build",
            "detail": "Build Docker image"
        }
    ]
}